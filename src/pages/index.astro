---
import Base from './layouts/base.astro';
import Header from './components/headers.astro';
import HubButton from './components/HubButton.astro';
import menu from './data/menu.json';

const { nombre, tagline, whatsapp, instagramUrl, reviewsUrl, mapsUrl } = menu.negocio;
const whatsappLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent("Olá! Vim pelo link do cardápio.")}`;
---
<Base title={nombre}>
  <div class="hub">
    <div class="hub__avatar">☕</div>
    <Header nombre={nombre} tagline={tagline} />

    <nav class="hub__botones">
      <HubButton texto="Cardápio" href="/cardapio" />
      <HubButton texto="WhatsApp" href={whatsappLink} externo={true} />
      <HubButton texto="Nos avalie ⭐" subtexto="Google Reviews" href={reviewsUrl} externo={true} />
      <HubButton texto="Localização" subtexto="Ver no mapa" href={mapsUrl} externo={true} />
    </nav>
  </div>
</Base>

<style>
  .hub {
    max-width: 420px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hub__avatar {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    background: var(--sage);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .hub__botones {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }
</style>