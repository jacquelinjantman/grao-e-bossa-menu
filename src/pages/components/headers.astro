---
const { nombre, tagline } = Astro.props;
---

<header class="header">
  <h1 class="header__nombre">{nombre}</h1>
  <p class="header__tagline">{tagline}</p>
</header>

<style>
  .header {
    text-align: center;
    padding: 3rem 1.5rem 2rem;
  }

  .header__nombre {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 600;
    color: var(--coffee);
  }

  .header__tagline {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--caramel);
    letter-spacing: 0.02em;
    margin: 1 rem;
  }
</style>
