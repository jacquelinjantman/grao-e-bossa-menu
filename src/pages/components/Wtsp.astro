---
const { numero, mensaje = "Olá! Gostaria de fazer um pedido." } = Astro.props;
const mensajeCodificado = encodeURIComponent(mensaje);
const link = `https://wa.me/${numero}?text=${mensajeCodificado}`;
---

<a
  href={link}
  class="whatsapp"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar no WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" class="whatsapp__icono">
    <path
      d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.9 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.85 1h.01a7.94 7.94 0 0 0 5.54-13.58ZM12.05 18.4h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.43-.16-.25a6.6 6.6 0 1 1 12.24-3.5 6.55 6.55 0 0 1-6.64 6.6Zm3.6-4.94c-.2-.1-1.17-.58-1.35-.64s-.31-.1-.44.1-.51.64-.62.77-.23.15-.42.05a5.4 5.4 0 0 1-1.6-.98 6 6 0 0 1-1.1-1.37c-.12-.2 0-.3.09-.4s.2-.23.3-.35.13-.2.2-.33a.36.36 0 0 0 0-.35c-.05-.1-.44-1.06-.6-1.45-.16-.38-.32-.33-.44-.33h-.38a.72.72 0 0 0-.52.24 2.2 2.2 0 0 0-.68 1.63 3.8 3.8 0 0 0 .8 2.02 8.7 8.7 0 0 0 3.33 2.95c.47.2.83.32 1.11.41a2.68 2.68 0 0 0 1.23.08c.38-.06 1.17-.48 1.33-.94s.17-.86.12-.94-.18-.13-.38-.23Z"
    ></path>
  </svg>
</a>

<style>
  .whatsapp {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 3.2rem;
    height: 3.2rem;
    background: #25d366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(43, 27, 20, 0.25);
    z-index: 50;
    transition: transform 0.2s ease;
  }

  .whatsapp : hover {
    transform: scale(1.08);
  }

  .whatsapp__icono {
    width: 1.7rem;
    height: 1.7rem;
    color: white;
  }
</style>
